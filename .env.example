# ---- Copy this file to ".env" and fill in your real values. ----
# .env is git-ignored. Never commit real keys.

# Apify (discovery). Get from https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brevo (sending). Get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OUTREACH list — wired to your Brevo automation. Adding a contact here sends the email.
BREVO_LIST_ID=2

# QUEUE list — a SECOND Brevo list (NO automation) that holds candidates waiting
# to be emailed. Create it in Brevo, then put its numeric ID here.
# Flow: discover/seed -> QUEUE ; send job moves 100/day QUEUE -> OUTREACH (=sends).
BREVO_QUEUE_LIST_ID=3

# Follower band for "micro/medium" influencers (inclusive).
FOLLOWER_MIN=10000
FOLLOWER_MAX=120000

# Hashtags to discover from (comma-separated, no # symbol).
HASHTAGS=gentleparenting,momlife,toddlermom,screentimedetox,momsofinstagram,toddlermomlife,consciousparenting,parentingtips

# How many recent posts to pull per hashtag (controls Apify credit spend).
POSTS_PER_HASHTAG=80
