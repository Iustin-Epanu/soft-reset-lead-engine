# ---- Copy this file to ".env" and fill in your real values. ----
# .env is git-ignored. Never commit real keys.

# Apify (discovery). Get from https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brevo (sending). Get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OUTREACH list — wired to your Brevo automation. Adding a contact here sends the email.
BREVO_LIST_ID=2

# QUEUE list — a SECOND Brevo list (NO automation) that holds candidates waiting
# to be emailed. Create it in Brevo, then put its numeric ID here.
# Flow: discover/seed -> QUEUE ; send job moves 100/day QUEUE -> OUTREACH (=sends).
BREVO_QUEUE_LIST_ID=3

# Follower band for "micro/medium" influencers (inclusive). Widened to 5k-250k
# to catch nano-influencers and larger creators (only ~7% of discovered accounts
# fell in the old 10k-120k band).
FOLLOWER_MIN=5000
FOLLOWER_MAX=250000

# Hashtags to discover from (comma-separated, no # symbol).
# Creator/monetizer-dense tags (bloggers, coaches, UGC, mompreneurs) yield FAR
# more public bio emails than broad personal tags like #momlife / #momsofinstagram,
# which are flooded with sub-1k personal accounts that never list an email.
HASHTAGS=momcontentcreator,momblogger,parentingcoach,gentleparenting,consciousparenting,motherhoodunplugged,parentinginfluencer,mompreneur

# How many recent posts to pull per hashtag (controls Apify credit spend).
POSTS_PER_HASHTAG=8

# Only scrape this many hashtags per run, as a window that rotates daily so the
# full HASHTAGS set still gets covered over time. 0 = scrape all every run.
HASHTAGS_PER_RUN=4

# Apify FREE-TIER SPEND GUARD. The free plan = ~$5/month ≈ ~1,800 results at
# ~$2.70/1,000. discover.py tallies results consumed per billing cycle in
# apify_usage.json and HARD-STOPS at this cap, so it can never overshoot the
# free credit (which would lock the account and tempt a daily account swap).
# One permanent account, forever free. Raise this to ~28000 when Apify
# Creator-plan credits (~$500/6mo) are active.
APIFY_MONTHLY_RESULT_CAP=1700
